# Heslo k PostgreSQL databázi
DB_PASSWORD=silne-heslo-sem

# JWT tajný klíč — vygenerujte: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=sem-vlozit-nahodny-retezec

# Veřejná URL API (bez lomítka na konci)
# Pokud běžíte lokálně, použijte: http://localhost:3001
# Na VPS s doménou: https://api.vas-domen.cz
VITE_API_URL=http://localhost:3001

# Veřejná URL formuláře (bez lomítka na konci)
# Pokud běžíte lokálně, použijte: http://localhost:3002
# Na VPS s doménou: https://form.vas-domen.cz
VITE_FORM_BASE_URL=http://localhost:3002

# Google Analytics Measurement ID pro systémový tracking (volitelné)
# Formát: G-XXXXXXXXXX
# Pokud nevyplníte, GA tracking v rezervačním formuláři nebude aktivní
VITE_GA_ID=
