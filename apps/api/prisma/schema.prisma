generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                  String   @id @default(cuid())
  name                String
  slug                String   @unique
  billingName         String   @default("")
  country             String   @default("")
  ico                 String   @default("")
  dic                 String   @default("")
  address             String   @default("")
  city                String   @default("")
  zip                 String   @default("")
  contactPerson       String   @default("")
  phone               String   @default("")
  contactEmail        String   @default("")
  billingEmail        String   @default("")
  termsText           String   @default("") @db.Text
  requireTermsAcceptance Boolean @default(false)
  defaultLanguageCode String   @default("cs")
  thousandsSeparator  String   @default(" ")
  decimalSeparator    String   @default(",")
  internalNote        String?  @db.Text
  gaTrackingId        String?
  goSmsClientId       String   @default("")
  goSmsClientSecret   String   @default("")
  goSmsChannelId      Int?
  bookingEnabled      Boolean  @default(false)
  hideCopyright       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  users               User[]
  camps               Camp[]
  languages           Language[]
}

model User {
  id                      String        @id @default(cuid())
  name                    String
  email                   String        @unique
  passwordHash            String
  isSuperAdmin            Boolean       @default(false)
  permissions             Json          @default("{}")
  reservationsDefaultView String        @default("list")
  tokenVersion            Int           @default(0)
  organizationId          String?
  organization            Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model SystemSettings {
  id                  String   @id @default("singleton")
  defaultLanguageCode String   @default("cs")
  thousandsSeparator  String   @default(" ")
  decimalSeparator    String   @default(",")
  smtpEnabled         Boolean  @default(true)
  globalTokenVersion  Int      @default(0)
  updatedAt           DateTime @updatedAt
}

model Language {
  id               String        @id @default(cuid())
  code             String
  name             String
  isDefault        Boolean       @default(false)
  currencyCode     String        @default("CZK")
  currencySymbol   String        @default("Kč")
  currencyPosition String        @default("after")
  organizationId   String?
  organization     Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt        DateTime      @default(now())

  @@unique([organizationId, code])
}

model Camp {
  id                    String              @id @default(cuid())
  name                  String
  slug                  String
  organizationId        String?
  organization          Organization?       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  notificationEmail     String
  smtpHost              String              @default("")
  smtpPort              Int                 @default(587)
  smtpUser              String              @default("")
  smtpPasswordEncrypted String              @default("")
  smtpFrom              String              @default("")
  smtpReplyTo           String              @default("")
  requiresConfirmation  Boolean             @default(true)
  hideAdults            Boolean             @default(false)
  hideChildren          Boolean             @default(false)
  useCustomSmtp         Boolean             @default(false)
  info                  Json                @default("{}")
  smsNotifyCustomer     Boolean             @default(false)
  smsNotifyAdmin        Boolean             @default(false)
  smsAdminPhones        String[]            @default([])
  smsTemplates          Json                @default("{}")
  bookingExportHash     String?             @unique
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt
  accommodationTypes    AccommodationType[]
  surcharges            Surcharge[]
  reservations          Reservation[]
  emailTemplates        EmailTemplate[]
  blockedPeriods        BlockedPeriod[]

  @@unique([organizationId, slug])
}

model AccommodationType {
  id               String                  @id @default(cuid())
  campId           String
  camp             Camp                    @relation(fields: [campId], references: [id], onDelete: Cascade)
  translations     Json                    @default("{}")
  capacity         Int                     @default(1)
  maxAdults             Int?
  maxChildren           Int?
  bookingIcalUrl        String?
  bookingExportEnabled  Boolean             @default(false)
  sortOrder             Int                 @default(0)
  useDynamicPricing     Boolean             @default(false)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  prices           AccommodationTypePrice[]
  nightTiers       NightTier[]
  reservations     Reservation[]
  blockedPeriods   BlockedPeriod[]
}

model NightTier {
  id                  String            @id @default(cuid())
  accommodationTypeId String
  accommodationType   AccommodationType @relation(fields: [accommodationTypeId], references: [id], onDelete: Cascade)
  fromNight           Int
  prices              NightTierPrice[]

  @@unique([accommodationTypeId, fromNight])
}

model NightTierPrice {
  id           String    @id @default(cuid())
  tierId       String
  tier         NightTier @relation(fields: [tierId], references: [id], onDelete: Cascade)
  languageCode String
  pricePerNight Float    @default(0)

  @@unique([tierId, languageCode])
}

model AccommodationTypePrice {
  id                  String            @id @default(cuid())
  accommodationTypeId String
  accommodationType   AccommodationType @relation(fields: [accommodationTypeId], references: [id], onDelete: Cascade)
  languageCode        String
  pricePerNight       Float             @default(0)
  adultPricePerNight  Float             @default(0)
  childPricePerNight  Float             @default(0)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  @@unique([accommodationTypeId, languageCode])
}

model Surcharge {
  id            String               @id @default(cuid())
  campId        String
  camp          Camp                 @relation(fields: [campId], references: [id], onDelete: Cascade)
  isOptional           Boolean              @default(true)
  isHidden             Boolean              @default(false)
  translations         Json                 @default("{}")
  sortOrder            Int                  @default(0)
  applicableTypeIds    String[]             @default([])
  createdAt     DateTime             @default(now())
  prices        SurchargePrice[]
  reservationSurcharges ReservationSurcharge[]
}

model SurchargePrice {
  id           String    @id @default(cuid())
  surchargeId  String
  surcharge    Surcharge @relation(fields: [surchargeId], references: [id], onDelete: Cascade)
  languageCode String
  pricePerNight Float    @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([surchargeId, languageCode])
}

model Reservation {
  id                  String               @id @default(cuid())
  campId              String
  camp                Camp                 @relation(fields: [campId], references: [id], onDelete: Restrict)
  accommodationTypeId String
  accommodationType   AccommodationType    @relation(fields: [accommodationTypeId], references: [id], onDelete: Restrict)
  checkIn             DateTime
  checkOut            DateTime
  adults              Int
  children            Int
  firstName           String
  lastName            String
  email               String
  phone               String
  licensePlate        String?
  expectedArrival     String?
  note                String?
  internalNote        String?              @db.Text
  totalPrice          Float
  priceSnapshot       Json?
  bookingCode         String?              @unique
  status              String               @default("PENDING")
  languageCode        String               @default("cs")
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  surcharges          ReservationSurcharge[]
}

model ReservationSurcharge {
  id            String      @id @default(cuid())
  reservationId String
  reservation   Reservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  surchargeId   String
  surcharge     Surcharge   @relation(fields: [surchargeId], references: [id], onDelete: Restrict)
  priceSnapshot Float

  @@unique([reservationId, surchargeId])
}

model BlockedPeriod {
  id                  String             @id @default(cuid())
  campId              String
  camp                Camp               @relation(fields: [campId], references: [id], onDelete: Cascade)
  accommodationTypeId String?
  accommodationType   AccommodationType? @relation(fields: [accommodationTypeId], references: [id], onDelete: Cascade)
  dateFrom            DateTime
  dateTo              DateTime
  reason              String             @default("")
  internalNote        String?            @db.Text
  source              String             @default("manual")
  externalUid         String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
}

model Motd {
  id            String   @id @default(cuid())
  title         String
  body          String   @db.Text
  color         String   @default("primary")
  closeable     Boolean  @default(true)
  showDashboard Boolean  @default(true)
  showGlobal    Boolean  @default(false)
  showMenu      Boolean  @default(false)
  linkUrl       String?
  linkLabel     String?
  active        Boolean  @default(true)
  validFrom     DateTime
  validTo       DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  userEmail String
  ip        String?
  action    String
  entity    String
  entityId  String?
  payload   Json?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([entity])
  @@index([userId])
}

model EmailTemplate {
  id           String   @id @default(cuid())
  campId       String
  camp         Camp     @relation(fields: [campId], references: [id], onDelete: Cascade)
  type         String
  languageCode String
  subject      String
  body         String   @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([campId, type, languageCode])
}
